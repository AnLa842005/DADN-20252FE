PORT=3001
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/yolo_farm
CORS_ORIGINS=http://localhost:8081
ADAFRUIT_IO_BROKER=io.adafruit.com
ADAFRUIT_IO_PORT=1883
ADAFRUIT_IO_USE_TLS=false
ADAFRUIT_IO_USERNAME=your-adafruit-username
ADAFRUIT_IO_KEY=your-adafruit-key
FEED_TEMP_KEY=yolo-farm-temp
FEED_AIR_HUMIDITY_KEY=yolo-farm-air-humidity
FEED_SOIL_HUMIDITY_KEY=yolo-farm-soil-humidity
FEED_LIGHT_KEY=yolo-farm-light
FEED_FAN_KEY=yolo-farm-fan
FEED_PUMP_KEY=yolo-farm-pump
FEED_SPEAKER_KEY=yolo-farm-speaker
FEED_RGB_KEY=yolo-farm-rgb
FEED_STATUS_KEY=yolo-farm-status
FEED_STREAM_KEY=yolo-farm-stream
SUBSCRIBE_FEEDS=temp,air_humidity,soil_humidity,light,status,stream
SERIAL_PORT=COM3
SERIAL_BAUD=115200
COMMAND_PAYLOAD_FORMAT=raw
GATEWAY_SERIAL_COMMAND_FORMAT=raw
GATEWAY_SUBSCRIBE_FEEDS=fan,pump,speaker,rgb,status,stream
GATEWAY_PUBLISH_FEEDS=temp,air_humidity,soil_humidity,light,status,stream
COMMAND_ACK_TIMEOUT_MS=15000
